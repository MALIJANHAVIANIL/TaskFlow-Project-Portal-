# ============================================
# Smart Task & Team Management Portal
# Environment Variables Configuration
# ============================================

# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Atlas Connection
# Replace with your MongoDB Atlas connection string
# Get it from: https://cloud.mongodb.com → Connect → Connect your application
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/task-management?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_123!
JWT_EXPIRE=30d

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173
